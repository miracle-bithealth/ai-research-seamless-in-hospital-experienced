# ==========================================
# App Info
# ==========================================
APP_ENV=local
APP_NAME=ai-seamless-hospital
APP_VERSION=0.1.0

# ==========================================
# App Config
# ==========================================
SCHEDULER_TIMEZONE=Asia/Jakarta
LIMIT_ALEMBIC_SCOPE=0
ENABLE_CRONJOB=0
ENABLE_APM=0

# ==========================================
# Docker
# ==========================================
DOCKER_CONTAINER_NAME=seamless-hospital
DOCKER_PORTS=8000
DOCKER_WORKER_COUNT=1

# ==========================================
# Security
# ==========================================
JWT_HS_SECRET=
JWT_RS_PRIVATE_KEY=
JWT_RS_PUBLIC_KEY=
SIGNATURE_SECRET=
SIGNATURE_TIMEOUT=300
ALLOWED_ORIGINS=http://localhost:8080,http://localhost:5173
JWT_ROLES_INDEX=sub

# ==========================================
# Redis (General & Ratelimit)
# ==========================================
REDIS_RATELIMIT_HOST=localhost
REDIS_RATELIMIT_PORT=6379
REDIS_RATELIMIT_DB=0
CACHE_HOST=localhost
CACHE_PORT=6379
CACHE_DB=1
CACHE_PASSWORD=
CACHE_USERNAME=
CACHE_EXPIRES_SEC=3600

# ==========================================
# Database (PostgreSQL)
# ==========================================
DB_USER=postgres
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432
DB_NAME=seamless_hospital

# ==========================================
# Typesense
# ==========================================
TYPESENSE_API_KEY=
TYPESENSE_HOST=localhost
TYPESENSE_PORT=8108
TYPESENSE_PROTOCOL=http
TYPESENSE_PATH=

# ==========================================
# Clickhouse
# ==========================================
CLICKHOUSE_HOST=localhost
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=default

# ==========================================
# APM
# ==========================================
APM_SERVER_URL=http://localhost:8200
APM_SERVICE_NAME=seamless-hospital

# ==========================================
# Embedding Config
# ==========================================
BASE_URL_EMBED=
ASYNC_QWEN3_EMBED=

# ==========================================
# MongoDB
# ==========================================
MONGODB_TYPE=LOCAL
MONGODB_ATLAS_USERNAME=
MONGODB_ATLAS_PASSWORD=
MONGODB_ATLAS_HOST=
MONGODB_ATLAS_APP_NAME=

MONGODB_HOST=localhost
MONGODB_PORT=27017
MONGODB_USERNAME=
MONGODB_PASSWORD=
MONGODB_DB_NAME=seamless_hospital
MONGO_COLLECTION_NAME=graph_data

# ==========================================
# Model Config
# ==========================================
GEMINI_REGULAR_MODEL=
GEMINI_MINI_MODEL=
GEMINI_THINKING_MODEL=
OPENAI_REGULAR_MODEL=
OPENAI_MINI_MODEL=
OPENAI_THINKING_MODEL=

# ==========================================
# Vertex AI & Google API
# ==========================================
GOOGLE_PROJECT_NAME=
GOOGLE_LOCATION_NAME=
SERVICE_ACCOUNT_SCOPE=
SERVICE_ACCOUNT_FILE=

# ==========================================
# MCP
# ==========================================
MCP_CONFIG_AI_SEARCH=
MCP_CONFIG_HOPE_RETRIEVER=
MCP_SESSION=false
MCP_HEALTH_CHECK_URL=

# ==========================================
# Azure API
# ==========================================
AZURE_API_KEY=
AZURE_API_KEY_002=
AZURE_API_KEY_DEV=
AZURE_API_VERSION=
AZURE_API_VERSION_002=
AZURE_API_VERSION_DEV=
AZURE_ENDPOINT=
AZURE_ENDPOINT_002=
AZURE_ENDPOINT_DEV=

# ==========================================
# Claude Models
# ==========================================
CLAUDE_3_7_SONNET_MODEL=
CLAUDE_4_SONNET_MODEL=

# ==========================================
# AWS
# ==========================================
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ==========================================
# Other
# ==========================================
PHOENIX_API_KEY=
PHOENIX_ENDPOINT=
BASE_URL_UPLOADER=

# ==========================================
# Navigation System
# ==========================================
AI_SEARCH_BASE_URL=
AI_SEARCH_TIMEOUT_S=5.0
AI_SEARCH_WEBHOOK_URL=
VIRTUAL_QUEUE_BASE_URL=
PLAYWRIGHT_POOL_SIZE=2
PLAYWRIGHT_TIMEOUT_MS=30000
GRAPH_DATA_DIR=data/graphs
FLOOR_SVG_DIR=data/floors
S3_ROUTE_IMAGE_PREFIX=navigation/rendered/
GRAPH_SYNC_REDIS_CHANNEL=graph:update
ROUTE_CACHE_TTL_S=300
CB_FAILURE_THRESHOLD=5
CB_RECOVERY_TIMEOUT_S=30
DEFAULT_BUILDING=shlv

# ==========================================
# LLM Gateway (Siloam LiteLLM proxy)
# ==========================================
LLM_API_KEY=
LLM_BASE_URL=https://uat-ai-gateway.siloamhospitals.com/v1
LLM_MODEL=Claude-4.5-Haiku
